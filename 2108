import org.springframework.core.io.ByteArrayResource;
import org.springframework.core.io.Resource;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.util.LinkedMultiValueMap;
import org.springframework.util.MultiValueMap;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import jakarta.validation.Valid;
import jakarta.validation.constraints.NotNull;
import java.util.Map;
import java.util.UUID;
import java.util.Random;

@RestController
@RequestMapping("/api")
public class RandomMultipartController {

    private final Random random = new Random();

    // Вариант 1: Принимаем Map с UUID
    @PostMapping(value = "/random-multipart", 
                consumes = MediaType.APPLICATION_JSON_VALUE,
                produces = MediaType.MULTIPART_FORM_DATA_VALUE)
    public ResponseEntity<MultiValueMap<String, Object>> generateRandomMultipart(
            @RequestBody Map<String, String> request) {
        
        String uuid = request.get("uuid");
        MultiValueMap<String, Object> multipartData = generateRandomMultipartData(uuid);
        
        return ResponseEntity.ok()
                .contentType(MediaType.MULTIPART_FORM_DATA)
                .body(multipartData);
    }

    // Вариант 2: С DTO и валидацией Jakarta
    @PostMapping(value = "/random-multipart-valid", 
                consumes = MediaType.APPLICATION_JSON_VALUE,
                produces = MediaType.MULTIPART_FORM_DATA_VALUE)
    public ResponseEntity<MultiValueMap<String, Object>> generateRandomMultipartValid(
            @Valid @RequestBody UuidRequest request) {
        
        MultiValueMap<String, Object> multipartData = generateRandomMultipartData(request.getUuid().toString());
        
        return ResponseEntity.ok()
                .contentType(MediaType.MULTIPART_FORM_DATA)
                .body(multipartData);
    }

    private MultiValueMap<String, Object> generateRandomMultipartData(String uuid) {
        MultiValueMap<String, Object> multipartData = new LinkedMultiValueMap<>();
        
        // Добавляем текстовые поля
        multipartData.add("receivedUuid", uuid != null ? uuid : "not-provided");
        multipartData.add("responseId", UUID.randomUUID().toString());
        multipartData.add("timestamp", String.valueOf(System.currentTimeMillis()));
        multipartData.add("status", "success");
        multipartData.add("randomValue", String.valueOf(random.nextInt(1000)));
        
        // Добавляем случайные файлы
        addRandomFile(multipartData, "document.txt", "text/plain", 
                     generateRandomTextContent());
        addRandomFile(multipartData, "data.json", "application/json", 
                     generateRandomJsonContent());
        addRandomFile(multipartData, "report.csv", "text/csv", 
                     generateRandomCsvContent());
        
        return multipartData;
    }

    private void addRandomFile(MultiValueMap<String, Object> multipartData, 
                             String filename, String contentType, String content) {
        ByteArrayResource resource = new ByteArrayResource(content.getBytes()) {
            @Override
        public String getFilename() {
                return filename;
            }
        };
        
        multipartData.add(filename, resource);
    }

    private String generateRandomTextContent() {
        String[] texts = {
            "Сгенерированный текстовый файл",
            "Случайное содержимое: " + System.currentTimeMillis(),
            "UUID запроса был обработан успешно",
            "Результат обработки: " + random.nextInt(10000)
        };
        return texts[random.nextInt(texts.length)];
    }

    private String generateRandomJsonContent() {
        return String.format("""
            {
                "responseId": "%s",
                "generatedAt": %d,
                "isSuccessful": %s,
                "data": {"field1": "value1", "field2": %d}
            }
            """, UUID.randomUUID(), System.currentTimeMillis(), 
            random.nextBoolean(), random.nextInt(100));
    }

    private String generateRandomCsvContent() {
        return String.format("""
            id,name,value,timestamp
            %d,item_%d,%d,%d
            %d,item_%d,%d,%d
            %d,item_%d,%d,%d
            """, 
            random.nextInt(100), random.nextInt(100), random.nextInt(1000), System.currentTimeMillis(),
            random.nextInt(100), random.nextInt(100), random.nextInt(1000), System.currentTimeMillis(),
            random.nextInt(100), random.nextInt(100), random.nextInt(1000), System.currentTimeMillis());
    }
}
