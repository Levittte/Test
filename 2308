import org.springframework.http.*;
import org.springframework.util.LinkedMultiValueMap;
import org.springframework.util.MultiValueMap;
import org.springframework.web.client.RestTemplate;
import org.springframework.web.multipart.MultipartFile;
import org.springframework.mock.web.MockMultipartHttpServletRequest;
import org.springframework.mock.web.MockServletContext;
import org.springframework.web.multipart.support.StandardServletMultipartResolver;
import javax.servlet.http.HttpServletRequest;
import java.io.IOException;
import java.util.Base64;
import java.util.Map;

@Service
public class MultipartService {
    
    @Autowired
    private RestTemplate restTemplate;
    
    /**
     * Получает multipart ответ и преобразует указанную часть в Base64
     */
    public String getPartAsBase64(String url, String targetPartName) throws IOException {
        // Отправляем запрос и получаем raw данные
        ResponseEntity<byte[]> response = restTemplate.getForEntity(url, byte[].class);
        
        // Парсим multipart ответ
        Map<String, MultipartFile> parts = parseMultipartResponse(response);
        
        // Ищем нужную часть
        MultipartFile targetFile = parts.get(targetPartName);
        if (targetFile == null) {
            throw new RuntimeException("Part '" + targetPartName + "' not found in response");
        }
        
        // Преобразуем в Base64
        return convertToBase64(targetFile);
    }
    
    /**
     * Парсит multipart ответ используя Spring утилиты
     */
    private Map<String, MultipartFile> parseMultipartResponse(ResponseEntity<byte[]> response) throws IOException {
        String contentType = response.getHeaders().getContentType().toString();
        byte[] content = response.getBody();
        
        // Создаем mock request для парсинга
        MockMultipartHttpServletRequest mockRequest = new MockMultipartHttpServletRequest();
        mockRequest.setContentType(contentType);
        mockRequest.setContent(content);
        
        // Используем StandardServletMultipartResolver для парсинга
        StandardServletMultipartResolver multipartResolver = new StandardServletMultipartResolver();
        
        if (!multipartResolver.isMultipart(mockRequest)) {
            throw new RuntimeException("Response is not multipart");
        }
        
        HttpServletRequest parsedRequest = multipartResolver.resolveMultipart(mockRequest);
        if (parsedRequest instanceof MockMultipartHttpServletRequest) {
            MockMultipartHttpServletRequest multipartRequest = (MockMultipartHttpServletRequest) parsedRequest;
            return multipartRequest.getFileMap();
        }
        
        throw new RuntimeException("Failed to parse multipart response");
    }
    
    /**
     * Преобразует MultipartFile в Base64 строку
     */
    private String convertToBase64(MultipartFile file) throws IOException {
        byte[] fileContent = file.getBytes();
        return Base64.getEncoder().encodeToString(fileContent);
    }
    
    /**
     * Альтернативный метод: получает все части как Base64
     */
    public Map<String, String> getAllPartsAsBase64(String url) throws IOException {
        ResponseEntity<byte[]> response = restTemplate.getForEntity(url, byte[].class);
        Map<String, MultipartFile> parts = parseMultipartResponse(response);
        
        Map<String, String> result = new HashMap<>();
        for (Map.Entry<String, MultipartFile> entry : parts.entrySet()) {
            result.put(entry.getKey(), convertToBase64(entry.getValue()));
        }
        
        return result;
    }
}
