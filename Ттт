package com.example.mapper;

import com.example.dto.DefectAccountFlatDto;
import com.example.dto.AccountDto;
import com.example.entity.CCDefectEntity;
import com.example.entity.AccountEntity;
import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;
import org.springframework.stereotype.Component;
import org.springframework.util.CollectionUtils;
import java.util.Collections;
import java.util.List;
import java.util.Set;
import java.util.stream.Collectors;

@Slf4j
@Component
@RequiredArgsConstructor
public class DefectAccountMapper {
    
    /**
     * Преобразует AccountEntity в AccountDto
     */
    private AccountDto toAccountDto(AccountEntity account) {
        if (account == null) {
            return null;
        }
        
        return AccountDto.builder()
            .id(account.id)           // прямой доступ к полю
            .username(account.username)
            .build();
    }
    
    /**
     * Преобразует пару Defect + Account в плоский DTO
     */
    private DefectAccountFlatDto toFlatDto(CCDefectEntity defect, AccountEntity account) {
        return DefectAccountFlatDto.builder()
            .defectId(defect.getId())
            .defectName(defect.getName())
            .defectDescription(defect.getDescription())
            .account(toAccountDto(account))  // ← вложенный AccountDto
            .build();
    }
    
    /**
     * Основной метод: список дефектов → плоский список DTO
     */
    public List<DefectAccountFlatDto> toFlatList(List<CCDefectEntity> defects) {
        if (defects == null || defects.isEmpty()) {
            return Collections.emptyList();
        }
        
        return defects.stream()
            .flatMap(defect -> {
                Set<AccountEntity> accounts = defect.getAccounts();
                
                if (CollectionUtils.isEmpty(accounts)) {
                    return Stream.of(toFlatDto(defect, null));
                }
                
                return accounts.stream()
                    .map(account -> toFlatDto(defect, account));
            })
            .collect(Collectors.toList());
    }
}
