3. Обновляем SidebarItem компонент (1000015414.jpg)

```typescript
import styles from './SidebarItem.module.css'; // исправляем импорт

interface SidebarItemProps {
    className?: string;
    item: SidebarItemType;
    collapsed: boolean;
}

export const SidebarItem = memo((props: SidebarItemProps) => {
    const { item, collapsed, className } = props;
    const dispatch = useAppDispatch();
    const location = useLocation();
    
    const activeSidebar = !item.isDownload && item.path === location.pathname;
    
    const handleClick = (e: React.MouseEvent) => {
        if (item.isDownload) {
            e.preventDefault(); // предотвращаем навигацию
            handleDownload();
        } else {
            // Обычная навигация
            dispatch(calculationActions.setSearchBy({ selectedSearchValue: '', searchInputValue: '' }));
        }
    };
    
    const handleDownload = async () => {
        try {
            // Импортируйте api функцию
            const { downloadReport } = await import('@shared/api/reports');
            const response = await downloadReport();
            
            // Конвертируем массив байт от Spring Boot
            const byteArray = new Uint8Array(response.fileContent);
            const blob = new Blob([byteArray], { type: response.contentType });
            
            // Скачиваем файл
            const url = window.URL.createObjectURL(blob);
            const link = document.createElement('a');
            link.href = url;
            link.download = response.fileName;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            window.URL.revokeObjectURL(url);
            
        } catch (error) {
            console.error('Ошибка скачивания:', error);
        }
    };
    
    return (
        <NavLink
            onClick={handleClick}
            to={item.path}
            className={clsx(styles.sidebarItem, className, {
                [styles.sidebarItemCollapsed]: collapsed,
                [styles.active]: activeSidebar,
            })}
        >
            <item.Icon 
                width={30} 
                height={30} 
                className={styles.sidebarIcon}
            />
            {!collapsed && ( // исправляем условие: показываем текст когда не collapsed
                <span className={clsx(styles.sidebarItemText, {
                    [styles.sidebarItemTextActive]: activeSidebar
                })}>
                    {item.text}
                </span>
            )}
        </NavLink>
    );
});
```

4. Sidebar компонент (1000015412.jpg) - остается без изменений

```typescript
import { SidebarItem } from './SidebarItem/SidebarItem';
import styles from './Sidebar.module.css';

interface SidebarProps {
    className?: string;
    collapsed: boolean;
    setActiveSidebar: (collapsed: boolean) => void;
}

export const Sidebar = memo((props: SidebarProps) => {
    const { className, collapsed, setActiveSidebar } = props;
    const permissions = useAppSelector(getCurrentPermissions);

    const renderSidebarItems = useMemo(() => {
        return getCurrentSidebarItemList(permissions as UserPermission[]).map((item) => (
            <SidebarItem
                item={item}
                collapsed={collapsed}
                key={item.text}
            />
        ));
    }, [collapsed, permissions]);

    return (
        <div className={clsx(styles.sidebar, { [styles.sidebarActive]: collapsed }, [className])}>
            {renderSidebarItems}
            <button
                onClick={() => setActiveSidebar(!collapsed)} // исправляем: передаем !collapsed
                className={styles.sidebarArrow}
            >
                {collapsed ? '→' : '←'} {/* или иконка */}
            </button>
        </div>
    );
});
```

5. API сервис (новый файл)

```typescript
// src/shared/api/reports.ts
import axios from 'axios';

export interface FileResponseDTO {
    fileName: string;
    fileContent: number[]; // массив байт от Spring Boot
    contentType: string;
}

export const downloadReport = async (): Promise<FileResponseDTO> => {
    const response = await axios.get<FileResponseDTO>('/api/reports/download');
    return response.data;
};
```

Ключевые изменения в вашем коде:

1. В SidebarItem:
   · Добавили проверку item.isDownload в handleClick
   · Исправили activeSidebar - не активен для пунктов скачивания
   · Исправили условие показа текста: !collapsed вместо collapsed
2. В функции фильтрации исправили логику:
   ```typescript
   // Было неправильно:
   return SidebarItemList.filter((permission) => SidebarItemType) === permissions.some((p) => p.permission);
   
   // Стало правильно:
   return SidebarItemList.filter(item => item.permission.some(p => permissions.includes(p)));
   ```
3. В Sidebar исправили кнопку:
