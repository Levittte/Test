public String getClientRealIp(HttpServletRequest request) {
    // 1. Проверяем заголовок X-Real-IP (его устанавливает Nginx)
    String ip = request.getHeader("X-Real-IP");
    
    // 2. Если его нет, проверяем X-Forwarded-For (первый IP в списке)
    if (ip == null || ip.isEmpty() || "unknown".equalsIgnoreCase(ip)) {
        ip = request.getHeader("X-Forwarded-For");
        if (ip != null && ip.contains(",")) {
            ip = ip.split(",")[0].trim();  // Берем первый IP из цепочки
        }
    }
    
    // 3. Если заголовков нет, используем getRemoteAddr()
    if (ip == null || ip.isEmpty() || "unknown".equalsIgnoreCase(ip)) {
        ip = request.getRemoteAddr();
    }
    
    return ip;
}

public String getLastProxyIp(HttpServletRequest request) {
    // 1. X-Forwarded-For содержит цепочку IP. Последний — это Nginx.
    String xForwardedFor = request.getHeader("X-Forwarded-For");
    if (xForwardedFor != null && xForwardedFor.contains(",")) {
        String[] ips = xForwardedFor.split(",");
        return ips[ips.length - 1].trim();
    }
    
    // 2. Если заголовка нет, значит запрос пришел напрямую (Nginx = клиент)
    return request.getRemoteAddr();
}
